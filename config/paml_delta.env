# paml_delta.env — NCSA Delta paths

# Single data root: unzip ciPHer-bench-paml-data.zip into <repo>/data/ first.
export PAML_DATA_DIR=/projects/bfzj/llindsey1/PHI_TSP/ciPHer-comparisons/paml/data

# Derived
export PAML_GENOPHI_REPO=${PAML_DATA_DIR}/GenoPHI
export PAML_TRAINED_MODEL=${PAML_DATA_DIR}/kp_train_output
export CIPHER_VAL_GENOMES=${PAML_DATA_DIR}/validation_genomes

# Cipher repo on Delta (canonical)
export CIPHER_REPO=/projects/bfzj/llindsey1/PHI_TSP/ciPHer

export PAML_CONDA_ENV=genophi

# SLURM defaults — DeltaAI / GPU partition (no Delta CPU allocation in
# our bfzj account). PAML's workload is CPU-bound (mmseqs2 + CatBoost),
# so the GPU just sits idle, but ghx4 is what's available.
export ACCOUNT=bfzj-dtai-gh
export PARTITION=ghx4
export GPUS_PER_NODE=1   # required on ghx4 even though we don't use it
